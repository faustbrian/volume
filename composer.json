{
    "name": "cline/volume",
    "description": "Volume and dimensional calculation utilities for PHP 8.4+",
    "license": "MIT",
    "keywords": [
        "php",
        "volume",
        "calculations",
        "dimensions",
        "measurements",
        "cubic-meters",
        "square-meters"
    ],
    "authors": [
        {
            "name": "Brian Faust",
            "email": "brian@cline.sh"
        }
    ],
    "require": {
        "php": "^8.5.0"
    },
    "require-dev": {
        "cline/coding-standard": "^2.0.1",
        "ergebnis/composer-normalize": "^2.50.0",
        "orchestra/testbench": "^10.9",
        "pestphp/pest": "^4.4.1",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.3",
        "symfony/var-dumper": "^7.4.6"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Cline\\Volume\\": "src"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "lint": "ecs check --fix",
        "refactor": "rector",
        "test": [
            "@test:lint",
            "@test:type-coverage",
            "@test:unit",
            "@test:types",
            "@test:refactor"
        ],
        "test:lint": "ecs check",
        "test:refactor": "rector --dry-run",
        "test:type-coverage": "pest --parallel --min=80 --type-coverage",
        "test:types": "phpstan",
        "test:unit": "pest --parallel --min=80 --coverage"
    }
}
